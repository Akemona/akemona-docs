{
  "name": "akemona-docs",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vocs dev",
    "build": "vocs build",
    "preview": "vocs preview",
    "deploy": "git pull && pnpm build",
    "deploy:dev": "git pull && DOCS_BASE_URL=https://docs.akemona-dev2.com pnpm build",
    "format": "prettier \"src/pages/**/*\" --write --ignore-unknown"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vocs": "2.0.14",
    "waku": "1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.2.0",
      "onFail": "download"
    }
  }
}
